#!hexa strict
// ──────────────────────────────────────────────────────────────────────────
// hexa-aura/tests/test_selftest.hexa — 4-pillar + 5-atlas presence + dispatcher selftest.
//
// @allow-relop-banned-file
// @allow-bare-exec-file
// @allow-silent-exit-file
//
// Pass criterion:
//   · all 4 pillar spec docs present  (clip/coil/cortex/safety)
//   · all 5 atlas docs present        (neuro/bci/neuromorphic/l9/neuroscience)
//   · .roadmap.hexa_aura present
//   · the CLI dispatcher emits `__HEXA_AURA_SELFTEST__ PASS`
//
// Cost: $0 (orchestrates the dispatcher; no numerical work).
// ──────────────────────────────────────────────────────────────────────────

let HOME = env("HOME")

let PILLAR_DOCS = [
    "clip/doc/mastoid-clip.md",
    "coil/doc/rt-sc-nanocoil.md",
    "cortex/doc/cortical-interface.md",
    "safety/doc/cortical-safety.md",
]
let ATLAS_DOCS = [
    "docs/neuro.md",
    "docs/brain-computer-interface.md",
    "docs/hexa-neuromorphic.md",
    "docs/l9-field-photon-neuro.md",
    "docs/neuroscience.md",
]

fn _exists(p: str) -> bool { return file_exists(p) }
fn _hexa_bin() -> str {
    let real = HOME + "/.hx/packages/hexa/hexa.real"  // @allow-devpath
    if file_exists(real) { return real }
    let h = exec("which hexa 2>/dev/null").trim()  // @allow-bare-exec
    if h.len() > 0 { return h }
    return HOME + "/.hx/bin/hexa"  // @allow-devpath
}

fn main() {
    let mut root = env("HEXA_AURA_ROOT")
    if root.len() == 0 { root = exec("pwd").trim() }  // @allow-bare-exec

    let mut missing: [str] = []
    for d in PILLAR_DOCS { if _exists(root + "/" + d) == false { missing = missing + [d] } }
    for d in ATLAS_DOCS  { if _exists(root + "/" + d) == false { missing = missing + [d] } }
    if _exists(root + "/.roadmap.hexa_aura") == false { missing = missing + [".roadmap.hexa_aura"] }

    let n_present = 4 + 5 + 1 - missing.len()
    println("test_selftest: docs+roadmap present = " + str(n_present) + " / 10  (4 pillar + 5 atlas + roadmap)")
    if missing.len() > 0 {
        println("test_selftest: FAIL — missing:")
        for m in missing { println("  - " + m) }
        exit(1)
    }

    let cli = root + "/cli/hexa-aura.hexa"
    if _exists(cli) == false { println("test_selftest: FAIL — cli/hexa-aura.hexa missing"); exit(1) }

    let cmd = "HEXA_AURA_ROOT=\"" + root + "\" \"" + _hexa_bin() + "\" run \"" + cli + "\" selftest 2>&1"
    let raw = exec(cmd)  // @allow-bare-exec
    if raw.find("__HEXA_AURA_SELFTEST__ PASS") > -1 {
        println("test_selftest: PASS — 4 pillar + 5 atlas + roadmap + dispatcher sentinel OK")
        return
    }
    println("test_selftest: FAIL — dispatcher sentinel not found")
    println(raw.trim())
    exit(1)
}
