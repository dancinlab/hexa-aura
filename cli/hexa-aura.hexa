        let mut js = "{\"hexa_aura\":\"" + VERSION + "\",\"subcmd\":\"status\","
        js = js + "\"pillars_total\":4,\"atlas_docs\":5,\"falsifiers\":4,\"falsifier_sub_ids\":15,"
        js = js + "\"verdict\":\"SPEC_FIRST_RSC\","
        js = js + "\"pillars\":[\"clip:F-AURA-1\",\"coil:F-AURA-2\",\"cortex:F-AURA-3\",\"safety:F-AURA-4\"]"
        js = js + "}"
        println(js)
        return
    }
    println("hexa-aura " + VERSION + " status — n=6 post-aural BCI substrate (측두골 클립)")
    println("")
    println("  pillar   spec doc                            falsifier   n=6 anchor")
    println("  -------- ----------------------------------- ----------- --------------------------------------------")
    println("  clip     clip/doc/mastoid-clip.md            F-AURA-1    φ=2 × σ·n/10 = 3.6 g, τ=4 anchor, sopfr=5 mm bone")
    println("  coil     coil/doc/rt-sc-nanocoil.md          F-AURA-2    μ=1 μm pitch, σ²=144 ch/tile, J₂=24/macro, n^τ=1296-ch hex")
    println("  cortex   cortex/doc/cortical-interface.md    F-AURA-3    σ=12 zones, φ=2 dir, τ=4 modes, sopfr=5 ms, 18-to-0 wearables")
    println("  safety   safety/doc/cortical-safety.md       F-AURA-4    Shannon k cap 1.5, SAR cap φ=2 W/kg, ΔT cap φ/τ=0.5 K, FAR cap μ=1 %, coating φ·σ=24 yr")
    println("")
    println("  atlas (5 background docs): neuro · brain-computer-interface · hexa-neuromorphic · l9-field-photon-neuro · neuroscience")
    println("    (neuro / brain-computer-interface = KR historically restored from canon@{579ab196, ab155706})")
    println("")
    println("  verdict: SPEC_FIRST_RSC (4 pillar specs + 5-doc atlas + RSC verify surface; F-AURA-1/2/3/4 all OPEN)")
    println("  cross-link: mind→pending · senses→pending · brain→sister · rtsc→sister (coil dep) · codex/chip/grid→CLI")
