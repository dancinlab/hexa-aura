    println("    hexa-aura selftest                          (4 pillar + 5 atlas presence + n=6 sanity)")
    println("    hexa-aura verify                            (n=6 invariant + per-pillar + parity audits)")
    _print_caveats()
}

// ─── subcommand: selftest ───

fn cmd_selftest(a: [str]) {
    println("hexa-aura selftest — 4 pillar + 5 atlas presence check + n=6 lattice sanity")
    println("")
    let mut pillars_ok = 0
    for row in PILLARS {
        let path = HM + "/" + row[1]
        if _file_exists(path) { println("  [PASS] pillar " + row[0] + " (" + row[2] + ")"); pillars_ok = pillars_ok + 1 }
        else { println("  [FAIL] pillar " + row[0] + " (missing: " + path + ")") }
    }
    let mut atlas_ok = 0
    for row in ATLAS {
        let path = HM + "/" + row[1]
        if _file_exists(path) { println("  [PASS] atlas  " + row[0]); atlas_ok = atlas_ok + 1 }
        else { println("  [FAIL] atlas  " + row[0] + " (missing: " + path + ")") }
    }
    let sigma = 12
    let tau = 4
    let phi = 2
    let n = 6
    let j2 = 24
    let lat_ok = (sigma * phi == j2) && (n * tau == j2) && (sigma * phi == n * tau) && (sigma * sigma == 144) && (sigma * sigma * sigma == 1728) && (n * n * n * n == 1296)
    if lat_ok { println("  [PASS] n=6 lattice: σ·φ = n·τ = J₂ = 24, σ²=144, σ³=1728, n^τ=1296") }
    else { println("  [FAIL] n=6 lattice arithmetic broken") }
    let roadmap_ok = _file_exists(HM + "/.roadmap.hexa_aura")
    if roadmap_ok { println("  [PASS] .roadmap.hexa_aura present") } else { println("  [FAIL] .roadmap.hexa_aura missing") }
    println("")
    println("pillars_present = " + str(pillars_ok) + " / 4")
    println("atlas_present   = " + str(atlas_ok) + " / 5")
    let all_ok = pillars_ok == 4 && atlas_ok == 5 && lat_ok && roadmap_ok
    if all_ok {
        println("__HEXA_AURA_SELFTEST__ PASS")
    } else {
        println("__HEXA_AURA_SELFTEST__ FAIL")
    }
    if json_mode(a) {
        println("{\"hexa_aura\":\"" + VERSION + "\",\"subcmd\":\"selftest\",\"pillars_present\":" + str(pillars_ok) +
                ",\"atlas_present\":" + str(atlas_ok) + ",\"lattice_ok\":" + (if lat_ok { "true" } else { "false" }) +
                ",\"verdict\":\"" + (if all_ok { "PASS" } else { "FAIL" }) + "\"}")
    }
    _print_caveats()
    _audit("selftest", "", if all_ok { 0 } else { 1 })
    if all_ok == false { exit(1) }
}

// ─── version / help ───

fn cmd_version() {
    println("hexa-aura " + VERSION)
    println("standalone n=6 post-aural BCI chip substrate (HEXA family)")
    println("4 pillars (clip / coil / cortex / safety) + 5-doc atlas + RSC verify surface (T1 x6 + T2 x4 + T3 x4 + cross-cutters x2 + meta x3)")
    println("license: MIT")
    println("repo:    https://github.com/dancinlab/hexa-aura")
}

fn cmd_help() {
    println("hexa-aura " + VERSION + " — standalone n=6 post-aural BCI CHIP-substrate CLI")
    println("")
    println("usage: hexa-aura <subcmd> [flags...]")
    println("")
    println("pillar subcommands (4-pillar post-aural BCI substrate — n=6 σ·φ = n·τ = J₂ = 24):")
    println("  clip            HEXA-MASTOID-CLIP    — form-factor (3.6 g/side, τ=4 anchor, sopfr=5 mm bone)   [F-AURA-1]")
    println("  coil            HEXA-RT-SC-NANOCOIL  — transducer (μ=1 μm pitch, σ²=144 ch/tile, J₂=24/macro)  [F-AURA-2]")
    println("  cortex          HEXA-CORTICAL-IF     — cortical I/O (σ=12 zones, φ=2 dir, τ=4 modes; 18-to-0)   [F-AURA-3]")
    println("  safety          HEXA-CORTICAL-SAFETY — caps (Shannon k 1.5, SAR 2 W/kg, ΔT 0.5 K, FAR 1 %, MRI-cond) [F-AURA-4]")
    println("")
    println("atlas verbs (5 background docs):")
    println("  neuro · brain_computer_interface · hexa_neuromorphic · l9_field_photon_neuro · neuroscience")
    println("")
    println("utility subcommands:")
    println("  status          4-pillar + 5-atlas table + verdict + cross-link + caveats")
    println("  selftest        4 pillar + 5 atlas presence + n=6 lattice sanity")
    println("  verify [<sub>]  RSC surface — sub: all (default) | lattice | cross-doc | clip | coil | cortex | safety")
    println("                       | numerics-clip | numerics-coil | numerics-cortex | numerics-safety")
    println("                       | numerics-clip-parity | numerics-coil-parity | numerics-cortex-parity | numerics-safety-parity")
    println("                       | numerics-clip-solver | numerics-coil-solver | numerics-cortex-solver | numerics-safety-solver")
    println("                       | numerics-cross | numerics-lattice | falsifier | lint-numerics | saturation")
    println("")
    println("global flags: --version, --help, -h, --json")
    println("env:          HEXA_AURA_ROOT (override repo root)")
    println("")
    println("cross-link (call sibling repo / CLI directly — DO NOT proxy through hexa-aura):")
    println("  cognitive verbs / BCI ML stack → hexa-mind  (pending)")
    println("  sensory verbs                  → hexa-senses (pending)")
    println("  working EEG/BMI pipeline        → hexa-brain (sister)")
    println("  RT-SC ambient SC (coil dep)     → hexa-rtsc  (sister)")
    println("  decoder model serving           → hexa-codex serve")
    println("  neuromorphic silicon            → hexa-chip neuromorphic")
    println("  5G/6G uplink for cloud sync     → hexa-grid v2x")
    println("")
    println("cost (Mac local): $0 — spec read + CLI dispatcher; verify/* are pure-hexa local audits.")
    println("backend specs: " + HM)
}

// ─── main ───

fn main(args: [str]) {
    if args.len() < 2 { cmd_help(); return }
    let sub = args[1]

    if sub == "--version" || sub == "-v" || sub == "version" { cmd_version(); return }
    if sub == "--help"    || sub == "-h" { cmd_help();    return }
    if sub == "help"      { cmd_help();    return }

    if sub == "status"   { cmd_status(args);   return }
    if sub == "selftest" { cmd_selftest(args); return }
    if sub == "verify"   { cmd_verify(args);   return }

    cmd_pillar(sub, args)
}
